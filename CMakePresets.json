{
    "version": 6,
    "configurePresets": [
        {
            "name": "macos",
            "displayName": "MacOS",
            "description": "Debug build with debug symbols for MacOS",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_CXX_FLAGS": "-fexperimental-library",
                "CMAKE_OSX_DEPLOYMENT_TARGET": "15.5",
                "ENABLE_TESTS": {
                    "type": "BOOL",
                    "value": "ON"
                }
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        },
        {
            "name": "arch",
            "displayName": "Yoneda",
            "description": "Debug build with debug symbols for Arch Linux",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "ENABLE_TESTS": {
                    "type": "BOOL",
                    "value": "ON"
                }
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        },
        {
            "name": "arch-release",
            "displayName": "Yoneda Release",
            "description": "Release build for Arch Linux",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "ENABLE_TESTS": {
                    "type": "BOOL",
                    "value": "ON"
                }
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        }

    ],
    "buildPresets": [
        {
            "name": "macos",
            "configurePreset": "macos"
        },
        {
            "name": "arch",
            "configurePreset": "arch"
        },
        {
            "name": "arch-release",
            "configurePreset": "arch-release"
        }
    ],
    "testPresets": [
      {
          "name": "arch",
          "displayName": "test-linux",
          "configurePreset": "arch",
          "output": {
              "outputOnFailure" : true,
              "verbosity": "verbose"
          },
          "filter": {
              "include":  { "name": "test" }
          }
      }  
    ],
    "workflowPresets": [
        {
            "name": "macos",
            "displayName": "Full workflow for macos",
            "steps": [
                { "name": "macos", "type": "configure" },
                { "name": "macos", "type": "build" }
            ]
        },
        {
            "name": "arch",
            "displayName": "Full workflow for arch",
            "steps": [
                { "name": "arch", "type": "configure" },
                { "name": "arch", "type": "build" },
                { "name": "arch", "type": "test"}
            ]
        },
        {
            "name": "arch-release",
            "displayName": "Full workflow for arch release",
            "steps": [
                { "name": "arch-release", "type": "configure" },
                { "name": "arch-release", "type": "build" }
            ]
        }
    ]
}
