{
    "version": 6,
    "configurePresets": [
        {
            "name": "macos",
            "displayName": "MacOS",
            "description": "Debug build with debug symbols of MacOS",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_CXX_FLAGS": "-fexperimental-library",
                "CMAKE_OSX_DEPLOYMENT_TARGET": "15.5",
                "ENABLE_TESTS": {
                    "type": "BOOL",
                    "value": "ON"
                }
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "macos",
            "configurePreset": "macos"
        }
    ]
}
